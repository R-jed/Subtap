#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# subtap launcher — 版本锁定、可回滚的 Python runtime 启动器
#
# 机制:
#   1. 从 Formula prefix 下的 version.txt 读取目标版本
#   2. 使用 ~/.subtap/runtime/$VERSION 作为锁定 runtime
#   3. 首次运行通过 uv 初始化 venv + pip install --require-hashes
#   4. 初始化完成后用 mv 原子替换，失败则保留旧 runtime 不受影响
# =============================================================================

# ---------------------------------------------------------------------------
# 路径解析
# ---------------------------------------------------------------------------

LAUNCHER_DIR="$(cd "$(dirname "$0")" && pwd)"
FORMULA_PREFIX="$(cd "$LAUNCHER_DIR/../" && pwd)"
SHARE_DIR="$FORMULA_PREFIX/share/subtap"
VERSION_FILE="$SHARE_DIR/version.txt"
REQUIREMENTS_FILE="$SHARE_DIR/runtime-requirements.txt"

RUNTIME_BASE="$HOME/.subtap/runtime"

# ---------------------------------------------------------------------------
# 读取版本
# ---------------------------------------------------------------------------

if [[ ! -f "$VERSION_FILE" ]]; then
  echo "ERROR: version.txt not found at $VERSION_FILE" >&2
  exit 1
fi

VERSION="$(cat "$VERSION_FILE" | tr -d '[:space:]')"
if [[ -z "$VERSION" ]]; then
  echo "ERROR: version.txt is empty" >&2
  exit 1
fi

RUNTIME_DIR="$RUNTIME_BASE/$VERSION"
RUNTIME_LOCK="$RUNTIME_DIR.lock"
RUNTIME_PARTIAL="$RUNTIME_DIR.partial"
RUNTIME_LOG="$RUNTIME_DIR.init.log"

# ---------------------------------------------------------------------------
# --bootstrap-info: 输出状态信息，不触发初始化
# ---------------------------------------------------------------------------

if [[ "${1:-}" == "--bootstrap-info" ]]; then
  echo "version=$VERSION"
  echo "runtime_dir=$RUNTIME_DIR"
  if [[ -d "$RUNTIME_DIR" ]]; then
    echo "initialized=true"
  else
    echo "initialized=false"
  fi
  exit 0
fi

# ---------------------------------------------------------------------------
# 确保 runtime 基础目录存在
# ---------------------------------------------------------------------------

mkdir -p "$RUNTIME_BASE"

# ---------------------------------------------------------------------------
# 首次初始化: 如果 runtime 目录不存在，通过 uv 创建
# ---------------------------------------------------------------------------

if [[ ! -d "$RUNTIME_DIR" ]]; then
  # 检查 requirements 文件
  if [[ ! -f "$REQUIREMENTS_FILE" ]]; then
    echo "ERROR: runtime-requirements.txt not found at $REQUIREMENTS_FILE" >&2
    exit 1
  fi

  # mkdir 原子锁，防止并发初始化
  if ! mkdir "$RUNTIME_LOCK" 2>/dev/null; then
    # 另一个进程正在初始化，等待锁释放
    echo "Waiting for concurrent initialization to complete..." >&2
    while [[ -d "$RUNTIME_LOCK" ]]; do
      sleep 0.5
    done
    # 锁释放后检查 runtime 是否已就绪
    if [[ -d "$RUNTIME_DIR" ]]; then
      exec "$RUNTIME_DIR/bin/subtap" "$@"
    else
      echo "ERROR: concurrent initialization failed" >&2
      exit 1
    fi
  fi

  # 清理函数: 释放锁
  cleanup() {
    rm -rf "$RUNTIME_LOCK"
    # 如果 partial 目录存在（初始化失败），保留日志后删除 partial
    if [[ -d "$RUNTIME_PARTIAL" ]]; then
      if [[ -f "$RUNTIME_LOG" ]]; then
        echo "ERROR: Initialization failed. Log preserved at $RUNTIME_LOG" >&2
      fi
      rm -rf "$RUNTIME_PARTIAL"
    fi
  }
  trap cleanup EXIT

  echo "Initializing subtap runtime $VERSION ..." >&2
  mkdir -p "$RUNTIME_PARTIAL"

  # 创建 venv
  uv venv --python 3.12 "$RUNTIME_PARTIAL" 2>"$RUNTIME_LOG"

  # 安装依赖 (带哈希校验)
  uv pip install \
    --python "$RUNTIME_PARTIAL/bin/python" \
    --require-hashes \
    -r "$REQUIREMENTS_FILE" \
    2>>"$RUNTIME_LOG"

  # 验证安装
  "$RUNTIME_PARTIAL/bin/subtap" version 2>>"$RUNTIME_LOG"

  # 原子替换: mv partial -> final
  # 成功前不会影响旧 runtime（如果有）
  mv "$RUNTIME_PARTIAL" "$RUNTIME_DIR"

  echo "Runtime $VERSION initialized successfully." >&2
fi

# ---------------------------------------------------------------------------
# 执行 subtap
# ---------------------------------------------------------------------------

exec "$RUNTIME_DIR/bin/subtap" "$@"
