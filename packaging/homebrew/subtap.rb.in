# typed: false
# frozen_string_literal: true

class Subtap < Formula
  include Language::Python::Virtualenv

  desc "Offline subtitle transcription toolkit"
  homepage "https://github.com/R-jed/Subtap"
  version "VERSION_PLACEHOLDER"
  url "WHEELHOUSE_URL_PLACEHOLDER"
  sha256 "WHEELHOUSE_SHA256_PLACEHOLDER"
  license "MIT"

  depends_on "ffmpeg"
  depends_on "numpy"
  depends_on "python@3.13"
  depends_on "scipy"

  def install
    odie "Subtap supports Apple Silicon macOS only" unless OS.mac? && Hardware::CPU.arm?

    venv = virtualenv_create(libexec, "python3.13", system_site_packages: true)
    wheelhouse = buildpath
    venv.pip_install <<~EOS
      --no-index
      --find-links=#{wheelhouse/"wheels"}
      --no-deps
      --require-hashes
      --only-binary=:all:
      -r
      #{wheelhouse/"requirements.txt"}
    EOS
    pkgshare.install wheelhouse/"licenses.json"
    pkgshare.install wheelhouse/"THIRD_PARTY_LICENSES"
    bin.install_symlink Dir[libexec/"bin/subtap"]
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/subtap --version")
    assert_match '"checks"', shell_output("#{bin}/subtap doctor 2>&1")

    # Verify key modules are importable
    system libexec/"bin/python3", "-c", "import subtap"
    system libexec/"bin/python3", "-c", <<~PYTHON
      from pydub import AudioSegment
      from subtap.core.vad import _get_speech_segments_silero
      assert _get_speech_segments_silero(AudioSegment.silent(duration=1000)) == []
    PYTHON

    # NumPy / SciPy must come from Homebrew, not bundled in the venv
    numpy_loc = shell_output(
      libexec/"bin/python3 -c \"import numpy; print(numpy.__file__)\""
    ).strip
    assert_match Formula["numpy"].prefix.realpath.to_s, numpy_loc

    scipy_loc = shell_output(
      libexec/"bin/python3 -c \"import scipy; print(scipy.__file__)\""
    ).strip
    assert_match Formula["scipy"].prefix.realpath.to_s, scipy_loc

    # Ensure no duplicate copies inside the venv
    refute_predicate libexec/"lib/python3.13/site-packages/numpy", :exist?,
      "numpy must not be installed inside the venv (use Homebrew copy)"
    refute_predicate libexec/"lib/python3.13/site-packages/scipy", :exist?,
      "scipy must not be installed inside the venv (use Homebrew copy)"
  end
end
